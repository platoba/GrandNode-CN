# GrandNode-CN 环境变量

# 端口
GRANDNODE_PORT=8080

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme

# 域名（用于 SSL 和 Nginx）
DOMAIN=localhost

# 支付宝（沙箱/正式）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 微信支付
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/wechat/notify
